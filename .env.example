# Solana RPC Cache Service - Environment Variables
# Copy to .env and modify as needed

# ----------------------------------------------------------------------------
# Docker Platform Configuration
# ----------------------------------------------------------------------------
# Platform for pre-built images (prometheus, grafana)
# Options: linux/arm64 (Apple Silicon), linux/amd64 (Intel/AMD)
DOCKER_PLATFORM=linux/arm64

# ----------------------------------------------------------------------------
# PostgreSQL Configuration
# ----------------------------------------------------------------------------
POSTGRES_USER=solana
POSTGRES_PASSWORD=solana
POSTGRES_DB=solana
POSTGRES_PORT=5432
POSTGRES_PARAMS="?sslmode=disable"

# Application Database URL (constructed from POSTGRES_* variables)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}${POSTGRES_PARAMS}

# ----------------------------------------------------------------------------
# postgres-exporter Configuration
# ----------------------------------------------------------------------------
DATA_SOURCE_NAME=${DATABASE_URL}

# ----------------------------------------------------------------------------
# pgAdmin Configuration
# ----------------------------------------------------------------------------
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=solana_readonly
DATABASE_PASSWORD=readonly
PGADMIN_DISABLE_POSTFIX=true
PGADMIN_CONFIG_UPGRADE_CHECK_ENABLED=False
PGADMIN_CONFIG_CONSOLE_LOG_LEVEL=10

# ----------------------------------------------------------------------------
# Grafana Configuration
# ----------------------------------------------------------------------------
# Anonymous authentication (enabled for development)
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin
GF_AUTH_BASIC_ENABLED=false
GF_AUTH_DISABLE_LOGIN_FORM=true

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_TX_DISPLAY_COUNT=500
APP_TX_EXPLORER_URL=https://solscan.io/tx/
APP_PORT=8080
APP_HOST=0.0.0.0
