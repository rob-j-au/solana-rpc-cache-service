<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solana RPC Cache Service - Dev Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
      min-height: 100vh;
      padding: 2rem;
      background: linear-gradient(145deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      position: relative;
      overflow-x: hidden;
    }
    
    body::before {
      content: '';
      position: fixed;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: 
        radial-gradient(circle at 20% 20%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(255, 119, 198, 0.2) 0%, transparent 50%),
        radial-gradient(circle at 40% 60%, rgba(99, 179, 237, 0.2) 0%, transparent 40%);
      animation: aurora 20s ease-in-out infinite;
      z-index: -1;
    }
    
    @keyframes aurora {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      25% { transform: translate(2%, 2%) rotate(1deg); }
      50% { transform: translate(-1%, 3%) rotate(-1deg); }
      75% { transform: translate(3%, -2%) rotate(2deg); }
    }
    
    .container {
      max-width: 1280px;
      margin: 0 auto;
    }
    
    h1 {
      color: rgba(255, 255, 255, 0.95);
      text-align: center;
      margin-bottom: 3rem;
      font-size: 2.75rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
    }
    
    h1 span {
      background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.7) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.25rem;
    }
    
    .service-card {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 
        0 8px 32px rgba(0, 0, 0, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: inherit;
      display: block;
      position: relative;
      overflow: hidden;
    }
    
    .service-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    }
    
    .service-card:hover {
      transform: translateY(-4px) scale(1.01);
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(255, 255, 255, 0.2);
      box-shadow: 
        0 20px 40px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
    }
    
    .service-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.25rem;
    }
    
    .icon-blue { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .icon-green { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
    .icon-orange { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .icon-cyan { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    
    .service-name {
      font-size: 1.125rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.95);
      margin-bottom: 0.375rem;
      letter-spacing: -0.01em;
    }
    
    .service-description {
      color: rgba(255, 255, 255, 0.55);
      margin-bottom: 1rem;
      font-size: 0.875rem;
      line-height: 1.5;
      font-weight: 400;
    }
    
    .service-url {
      color: rgba(255, 255, 255, 0.7);
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.8rem;
      word-break: break-all;
      background: rgba(0, 0, 0, 0.2);
      padding: 0.5rem 0.75rem;
      border-radius: 8px;
      display: block;
    }
    
    .service-port {
      display: inline-block;
      background: rgba(255, 255, 255, 0.1);
      padding: 0.25rem 0.625rem;
      border-radius: 6px;
      font-size: 0.75rem;
      margin-top: 0.75rem;
      color: rgba(255, 255, 255, 0.6);
      font-weight: 500;
    }
    
    .category {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.75rem;
      margin: 2.5rem 0 1rem 0;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    
    .category:first-of-type {
      margin-top: 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1><span>Solana RPC Cache Service</span></h1>
    
    <div class="category">Services</div>
    <div class="services-grid">
      <a href="http://localhost:8080" target="_blank" class="service-card">
        <div class="service-icon icon-blue">🚀</div>
        <div class="service-name">Solana RPC Cache</div>
        <div class="service-description">Solana RPC caching service endpoint</div>
        <div class="service-url">http://localhost:8080</div>
        <span class="service-port">Port 8080</span>
      </a>
      
      <a href="http://localhost:8080/metrics" target="_blank" class="service-card">
        <div class="service-icon icon-orange">📈</div>
        <div class="service-name">Prometheus</div>
        <div class="service-description">Application metrics endpoint</div>
        <div class="service-url">http://localhost:8080/metrics</div>
        <span class="service-port">Port 8080</span>
      </a>
    </div>
    
    <div class="category">Database</div>
    <div class="services-grid">
      <a href="http://localhost:5050" target="_blank" class="service-card">
        <div class="service-icon icon-green">🗄️</div>
        <div class="service-name">pgAdmin (Read Only)</div>
        <div class="service-description">PostgreSQL web administration interface</div>
        <div class="service-url">http://localhost:5050</div>
        <span class="service-port">Port 5050</span>
      </a>
    </div>
    
    <div class="category">Monitoring & Observability</div>
    <div class="services-grid">
      <a href="http://localhost:3000/d/postgresql-database/postgresql-database" target="_blank" class="service-card">
        <div class="service-icon icon-orange">📊</div>
        <div class="service-name">Grafana</div>
        <div class="service-description">Metrics dashboards and visualization</div>
        <div class="service-url">Dashboard → PostgreSQL Database</div>
        <span class="service-port">Port 3000</span>
      </a>
      
      <a href="http://localhost:3000/a/grafana-lokiexplore-app/explore" target="_blank" class="service-card">
        <div class="service-icon icon-green">📜</div>
        <div class="service-name">Grafana Logs</div>
        <div class="service-description">Centralized container logs via Loki</div>
        <div class="service-url">Explore → Logs</div>
        <span class="service-port">Direct link</span>
      </a>
      
      <a href="http://localhost:9090" target="_blank" class="service-card">
        <div class="service-icon icon-orange">🔥</div>
        <div class="service-name">Prometheus</div>
        <div class="service-description">Metrics collection and monitoring</div>
        <div class="service-url">http://localhost:9090</div>
        <span class="service-port">Port 9090</span>
      </a>
      
      <a href="http://localhost:9187/metrics" target="_blank" class="service-card">
        <div class="service-icon icon-cyan">🐘</div>
        <div class="service-name">PostgreSQL Metrics</div>
        <div class="service-description">PostgreSQL exporter metrics</div>
        <div class="service-url">http://localhost:9187/metrics</div>
        <span class="service-port">Port 9187</span>
      </a>
    </div>
  </div>
</body>
</html>
